{
  "name": "goal-network-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "dev:open": "concurrently -k -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1 --open /\"",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "api": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "chokidar": "^4.0.3",
    "fastify": "^5.6.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
